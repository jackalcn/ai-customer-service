# 本機執行：將此檔案另存為 .env 並填入 API Key
# Streamlit Cloud：請將相同鍵值貼到 App 的 Secrets（非上傳 .env）
# AI_PROVIDER 可設為：auto / openai / gemini
AI_PROVIDER=auto

OPENAI_API_KEY=請在這裡放入你的 API Key
OPENAI_MODEL=gpt-4o-mini

# Google Gemini 金鑰可於 Google AI Studio 取得
GOOGLE_API_KEY=請在這裡放入你的 Google Gemini API Key
GEMINI_MODEL=gemini-1.5-flash
